# Netlify environment variables (Site settings -> Environment variables).
# Never commit real values.

# Google Apps Script web-app URL (ends with /exec) — from README step 4
APPS_SCRIPT_WEBHOOK_URL=

# Long random string; must equal the SHARED_SECRET Script Property in Apps Script
APPS_SCRIPT_SHARED_SECRET=

# Production origin, e.g. https://your-domain.example — requests from other origins are rejected
ALLOWED_ORIGIN=

# Random salt for one-way IP hashing (abuse control); rotate to invalidate old hashes
IP_HASH_SALT=
